        </mxCell>
        <mxCell id="ZUj22Poo5WALfulCWifB-23" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;Replace money and governments with human connections for everything you need.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Here&#39;s how to join:&lt;/div&gt;&lt;div&gt;1. Take a breath&lt;/div&gt;&lt;div&gt;2. Do something you&#39;re proud of&lt;/div&gt;&lt;div&gt;3. Repeat&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Laughter, play, joy, creation and gratitude are all part of being human. Even pain can be magical when we feel it fully.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;We&#39;re starting by doing things we&#39;re proud of in the present moment that make living a joy for ourselves and those around us today. We believe that by peacefully building alternative systems to the status quo&amp;nbsp;&lt;/div&gt;&lt;div&gt;Our goal is to ensure all humans can thrive without depending on governments or private companies.&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="301" width="360" x="137" y="342" as="geometry" />
        </mxCell>
        <mxCell id="ZUj22Poo5WALfulCWifB-24" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Webinar-style video to make people believe that it truly is possible" vertex="1">
          <mxGeometry height="60" width="162" x="516" y="350" as="geometry" />
        </mxCell>
        <mxCell id="ZUj22Poo5WALfulCWifB-25" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Reveal things in layers so we don&#39;t start with the most far-out beliefs" vertex="1">
          <mxGeometry height="60" width="162" x="516" y="270" as="geometry" />
        </mxCell>
